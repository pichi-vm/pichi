/dts-v1/;

/* 33 memory regions (cap = 32) — the 33rd push triggers
 * DtbError::TooManyMemoryRegions { found: 33 }.
 */
/ {
	#address-cells = <2>;
	#size-cells = <2>;
	model = "dtb2acpi-test/too-many-memory-regions";

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu@0 {
			device_type = "cpu";
			reg = <0>;
		};
	};

		lapic: interrupt-controller@fee00000 {
		compatible = "intel,ce4100-lapic";
		reg = <0x0 0xfee00000 0x0 0x1000>;
		interrupt-controller;
		#interrupt-cells = <2>;
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0x0 0x40000000 0x0 0x1000000>;
	};
	memory@41000000 {
		device_type = "memory";
		reg = <0x0 0x41000000 0x0 0x1000000>;
	};
	memory@42000000 {
		device_type = "memory";
		reg = <0x0 0x42000000 0x0 0x1000000>;
	};
	memory@43000000 {
		device_type = "memory";
		reg = <0x0 0x43000000 0x0 0x1000000>;
	};
	memory@44000000 {
		device_type = "memory";
		reg = <0x0 0x44000000 0x0 0x1000000>;
	};
	memory@45000000 {
		device_type = "memory";
		reg = <0x0 0x45000000 0x0 0x1000000>;
	};
